---
const MARKETING = 'https://www.aichatseo.com';
const year = new Date().getFullYear();
const links = [
  { label: 'Privacy Policy', href: `${MARKETING}/privacy` },
  { label: 'Terms of Service', href: `${MARKETING}/terms` },
  { label: 'Security', href: `${MARKETING}/security` },
  { label: 'API Documentation', href: `${MARKETING}/docs` },
];
---

<footer class="mt-auto border-t border-slate-200/80 bg-white/70 px-6 py-12 backdrop-blur-sm">
  <div class="mx-auto flex max-w-6xl flex-col gap-8 sm:flex-row sm:items-center sm:justify-between">
    <div class="text-sm text-slate-500">
      <p class="font-medium text-slate-800">aichatseo</p>
      <p class="mt-1">Get indexed, not perplexed.</p>
    </div>
    <ul class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
      {
        links.map((l) => (
          <li>
            <a href={l.href} class="text-slate-600 transition hover:text-sky-700">
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
  <p class="mx-auto mt-8 max-w-6xl text-center text-xs text-slate-400">
    © {year} AIChatSEO. All rights reserved.
  </p>
</footer>
