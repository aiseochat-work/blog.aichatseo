---
const MARKETING = 'https://www.aichatseo.com';
const nav = [
  { label: 'Features', href: `${MARKETING}/#features` },
  { label: 'Blog', href: '/' },
  { label: 'Pricing', href: `${MARKETING}/pricing` },
  { label: 'About', href: `${MARKETING}/about` },
];
const path = Astro.url.pathname;
const blogActive = path === '/' || path.startsWith('/blog');
---

<header class="sticky top-0 z-50 px-4 pb-2 pt-4 sm:px-6">
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 rounded-4xl border border-white/10 bg-slate-950/90 px-4 py-3 text-white shadow-soft backdrop-blur-md sm:px-6"
    aria-label="Primary"
  >
    <a
      href={MARKETING}
      class="flex shrink-0 items-center gap-2 font-semibold tracking-tight text-white"
    >
      <span
        class="grid h-9 w-9 place-items-center rounded-2xl bg-gradient-to-br from-sky-300 to-sky-600 text-sm font-bold text-slate-950 shadow-soft"
        aria-hidden="true"
      >
        AI
      </span>
      <span class="hidden sm:inline">aichatseo</span>
    </a>

    <ul class="hidden flex-1 items-center justify-center gap-1 md:flex">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'rounded-full px-3 py-2 text-sm font-medium transition',
                item.label === 'Blog' && blogActive && 'bg-white/10 text-sky-100',
                item.label === 'Blog' && !blogActive && 'text-slate-300 hover:bg-white/10 hover:text-white',
                item.label !== 'Blog' && 'text-slate-300 hover:bg-white/10 hover:text-white',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex shrink-0 items-center gap-2">
      <a
        href={`${MARKETING}/sign-in`}
        class="hidden rounded-full px-3 py-2 text-sm font-medium text-slate-300 transition hover:text-white sm:inline"
      >
        Log in
      </a>
      <a
        href={`${MARKETING}/sign-up`}
        class="inline-flex items-center justify-center rounded-full bg-white px-3 py-2 text-sm font-semibold text-slate-950 shadow-soft transition hover:bg-sky-100 sm:px-4"
      >
        Get Started Free
      </a>
    </div>
  </nav>

  <div class="mx-auto mt-2 flex max-w-6xl gap-1 overflow-x-auto pb-1 md:hidden" role="navigation" aria-label="Sections">
    {
      nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'shrink-0 rounded-full px-3 py-1.5 text-xs font-medium',
            item.label === 'Blog' && blogActive && 'bg-sky-100 text-sky-900',
            item.label === 'Blog' && !blogActive && 'bg-white/90 text-slate-600 ring-1 ring-slate-200',
            item.label !== 'Blog' && 'bg-white/90 text-slate-600 ring-1 ring-slate-200',
          ]}
        >
          {item.label}
        </a>
      ))
    }
  </div>
</header>
