---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { readingTimeMinutesFromMarkdown, wordCountFromMarkdown } from '../../lib/reading-time';
import { setBlogCacheHeaders } from '../../lib/cache';
import { absoluteUrl, canonicalFromRequest, SCHEMA_PUBLISHER_ORG_ID, blogDocumentBase, schemaBlogId, schemaWebSiteId } from '../../lib/site-url';
import { blogEntrySlug, blogHubAbsoluteUrl, BLOG_HUB_PATH } from '../../lib/blog-slug';
import { parseFaqsFromMarkdown } from '../../lib/parse-faq-from-markdown';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: blogEntrySlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const DEFAULT_AUTHOR = 'AIChatSEO Team';

const articleDesc =
  post.data.metaDescription?.trim() ||
  post.data.excerpt?.trim() ||
  post.data.description.trim() ||
  `${post.data.title} — insights from the AIChatSEO blog.`;

const cover = post.data.coverImage?.trim();
const ogImage = cover ? absoluteUrl(cover) : undefined;

const publishedIso = post.data.pubDate.toISOString();
const modifiedIso = (post.data.updatedDate ?? post.data.pubDate).toISOString();
const authorName = post.data.author?.trim() || DEFAULT_AUTHOR;
const readMins = readingTimeMinutesFromMarkdown(post.body);
const articleUrl = canonicalFromRequest(Astro.url);
const postTags = post.data.tags?.filter(Boolean) || [];
const extraSeo = post.data.seoKeywords?.filter(Boolean) || [];
const metaKeywordList = [...new Set([...postTags, ...extraSeo])];

const siteHomeUrl = blogDocumentBase();
const blogHubUrl = blogHubAbsoluteUrl();
const logoUrl = absoluteUrl('/favicon.svg');
const blogId = schemaBlogId();
const webSiteId = schemaWebSiteId();
const articleNodeId = `${articleUrl}#article`;

const organizationLd = {
  '@type': 'Organization',
  '@id': SCHEMA_PUBLISHER_ORG_ID,
  name: 'AIChatSEO',
  url: 'https://www.aichatseo.com',
  logo: {
    '@type': 'ImageObject',
    url: logoUrl,
  },
};

const webSiteStubLd = {
  '@type': 'WebSite',
  '@id': webSiteId,
  url: siteHomeUrl,
  name: 'AIChatSEO Blog',
  publisher: { '@id': SCHEMA_PUBLISHER_ORG_ID },
};

const blogStubLd = {
  '@type': 'Blog',
  '@id': blogId,
  name: 'AIChatSEO Blog',
  url: blogHubUrl,
  publisher: { '@id': SCHEMA_PUBLISHER_ORG_ID },
  isPartOf: { '@id': webSiteId },
};

const webPageLd = {
  '@type': 'WebPage',
  '@id': articleUrl,
  url: articleUrl,
  name: post.data.title,
  description: articleDesc,
  inLanguage: 'en-US',
  isPartOf: { '@id': blogId },
  publisher: { '@id': SCHEMA_PUBLISHER_ORG_ID },
};

const articleLd = {
  '@type': 'BlogPosting',
  '@id': articleNodeId,
  headline: post.data.title,
  description: articleDesc,
  url: articleUrl,
  mainEntityOfPage: { '@id': articleUrl },
  isPartOf: { '@id': blogId },
  datePublished: publishedIso,
  dateModified: modifiedIso,
  author: { '@type': 'Person', name: authorName },
  publisher: { '@id': SCHEMA_PUBLISHER_ORG_ID },
  image: ogImage ? [ogImage] : [logoUrl],
  articleSection: postTags[0] || 'SEO',
  ...(metaKeywordList.length > 0 ? { keywords: metaKeywordList } : {}),
  wordCount: wordCountFromMarkdown(post.body),
  timeRequired: `PT${readMins}M`,
};

const breadcrumbLd = {
  '@type': 'BreadcrumbList',
  '@id': `${articleUrl}#breadcrumb`,
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Blog',
      item: blogHubUrl,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: post.data.title,
      item: articleUrl,
    },
  ],
};

const graph: Record<string, unknown>[] = [
  organizationLd,
  webSiteStubLd,
  blogStubLd,
  webPageLd,
  articleLd,
  breadcrumbLd,
];

const explicitFaqs = post.data.faqs?.filter((f) => f.question?.trim() && f.answer?.trim());
const parsedFaqs = parseFaqsFromMarkdown(post.body);
/** Frontmatter wins if set; otherwise auto-detect `## FAQ` / `## Frequently Asked Questions` + `###` pairs in the body. */
const faqsForSchema = explicitFaqs?.length ? explicitFaqs : parsedFaqs;
if (faqsForSchema.length) {
  graph.push({
    '@type': 'FAQPage',
    '@id': `${articleUrl}#faq`,
    mainEntity: faqsForSchema.map((f) => ({
      '@type': 'Question',
      name: f.question.trim(),
      acceptedAnswer: {
        '@type': 'Answer',
        text: f.answer.trim(),
      },
    })),
  });
}

if (post.data.softwareApplicationSchema) {
  graph.push({
    '@type': 'SoftwareApplication',
    '@id': `${articleUrl}#software`,
    name: 'AIChatSEO',
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Web',
    description: articleDesc,
    url: 'https://www.aichatseo.com',
    publisher: { '@id': SCHEMA_PUBLISHER_ORG_ID },
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
      description: 'Free tier available; paid plans for teams.',
    },
  });
}

const howTo = post.data.howTo;
if (howTo?.steps?.length) {
  graph.push({
    '@type': 'HowTo',
    '@id': `${articleUrl}#howto`,
    name: howTo.name,
    ...(howTo.description ? { description: howTo.description } : {}),
    step: howTo.steps.map((s, i) => ({
      '@type': 'HowToStep',
      position: i + 1,
      name: s.name,
      text: s.text,
    })),
  });
}

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@graph': graph,
};

const deck = post.data.excerpt?.trim() || post.data.description;
const categorySlug = post.data.category;
const categoryHref = categorySlug ? `${BLOG_HUB_PATH}/${categorySlug}/` : undefined;

setBlogCacheHeaders(Astro.response.headers);
---

<Layout
  title={`${post.data.title} | AIChatSEO`}
  description={articleDesc}
  ogImage={ogImage}
  ogImageAlt={cover ? `Featured image: ${post.data.title}` : post.data.title}
  ogType="article"
  articlePublishedTime={publishedIso}
  articleModifiedTime={modifiedIso}
  articleTags={postTags}
  keywords={metaKeywordList}
  author={authorName}
  jsonLd={articleJsonLd}
>
  <main class="mx-auto max-w-6xl px-4 pb-24 pt-6 sm:px-6 sm:pt-10">
    <article class="flex flex-col items-center">
      <header class="mb-12 flex w-full flex-col justify-center">
        <div class="mb-8 flex w-full flex-wrap items-center justify-start gap-3">
          <a
            href={`${BLOG_HUB_PATH}/`}
            class="inline-flex min-h-10 items-center gap-2 rounded-full border border-white/90 bg-white/88 px-4 py-2 text-sm font-bold text-slate-700 shadow-[0_18px_40px_-32px_rgba(15,23,42,0.7)] transition-[background-color,transform] hover:bg-white active:scale-[0.96]"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            Back to blogs
          </a>
          {categoryHref && (
            <a
              href={categoryHref}
              class="inline-flex min-h-10 items-center rounded-full border border-[#80c4e9]/30 bg-white/78 px-4 py-2 text-xs font-bold uppercase tracking-[0.2em] text-[#3b7597] shadow-[0_18px_40px_-32px_rgba(59,117,151,0.35)] transition-[background-color,transform] hover:bg-white active:scale-[0.96]"
            >
              Topic hub
            </a>
          )}
        </div>

        <div class="overflow-hidden rounded-[2.5rem] border border-white/85 bg-[linear-gradient(145deg,rgba(255,255,255,0.94),rgba(238,249,255,0.96))] p-6 shadow-[0_30px_90px_-46px_rgba(15,23,42,0.34)] backdrop-blur-xl md:p-8 lg:p-10">
          <div class="grid gap-10 lg:grid-cols-[minmax(0,1.05fr)_320px] lg:items-end">
            <div class="max-w-3xl">
              <div class="mb-6 flex flex-wrap items-center gap-3">
                <p class="inline-flex items-center rounded-full border border-[#80c4e9]/20 bg-white/78 px-4 py-1.5 text-[11px] font-bold uppercase tracking-[0.22em] text-[#3b7597] shadow-[0_12px_30px_-24px_rgba(59,117,151,0.7)]">
                  {new Date(post.data.pubDate).toLocaleDateString("en-GB", {
                    day: "2-digit",
                    month: "short",
                    year: "numeric",
                  })}
                </p>
                <p class="inline-flex items-center rounded-full border border-slate-200 bg-white/78 px-4 py-1.5 text-[11px] font-bold uppercase tracking-[0.22em] text-slate-600">
                  {readMins} min read
                </p>
                <p class="inline-flex items-center rounded-full border border-slate-200 bg-white/78 px-4 py-1.5 text-[11px] font-bold uppercase tracking-[0.22em] text-slate-600">
                  {wordCountFromMarkdown(post.body).toLocaleString('en-US')} words
                </p>
              </div>

              <h1 class="max-w-4xl text-4xl font-extrabold leading-[0.95] tracking-tight text-slate-900 md:text-6xl lg:text-[4.5rem]">
                {post.data.title}
              </h1>

              <p class="font-editorial mt-6 max-w-2xl text-[1.35rem] font-medium leading-[1.65] text-slate-700 lg:text-[1.45rem]">
                {deck}
              </p>
            </div>

            <div class="grid gap-4">
              <div class="rounded-[1.75rem] border border-white/80 bg-white/78 p-4 shadow-[0_18px_40px_-34px_rgba(15,23,42,0.8)] backdrop-blur-md">
                <div class="flex items-center gap-3">
                  <div class="flex h-12 w-12 items-center justify-center rounded-[1rem] border border-white bg-[linear-gradient(180deg,#f8fbff,#eef7ff)] shadow-[0_16px_32px_-22px_rgba(15,23,42,0.55)]">
                    <span class="text-sm font-bold uppercase tracking-[0.18em] text-sky-700">{authorName[0]}</span>
                  </div>
                  <div class="min-w-0">
                    <p class="text-base font-bold leading-tight text-slate-900">
                      {authorName}
                    </p>
                    <p class="mt-1 text-[11px] font-bold uppercase tracking-[0.22em] text-slate-500">
                      AIChatSEO Editorial
                    </p>
                  </div>
                </div>
              </div>

              <div class="rounded-[1.75rem] border border-white/80 bg-white/78 p-4 shadow-[0_18px_40px_-34px_rgba(15,23,42,0.8)] backdrop-blur-md">
                <div class="text-[11px] font-bold uppercase tracking-[0.22em] text-[#3b7597]">
                  Article focus
                </div>
                <p class="mt-3 text-sm leading-7 text-slate-600">
                  Practical analysis for operators working through search visibility, reporting, and execution decisions.
                </p>
              </div>
            </div>
          </div>

          {cover && (
            <div class="relative mt-10 overflow-hidden rounded-[2rem] outline outline-1 outline-black/10 shadow-[0_28px_80px_-42px_rgba(15,23,42,0.34)] group">
              <div class="absolute inset-0 z-10 bg-gradient-to-t from-slate-950/30 via-transparent to-white/10"></div>
              <img
                src={cover}
                alt={post.data.title}
                class="h-[280px] w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.02] md:h-[380px] lg:h-[520px]"
              />
            </div>
          )}
        </div>
      </header>

      <div class="flex w-full flex-col gap-6 rounded-[2rem] border border-white/85 bg-white/84 px-6 py-6 shadow-[0_22px_70px_-42px_rgba(15,23,42,0.3)] backdrop-blur-xl sm:flex-row sm:items-center sm:justify-between">
        <div class="flex flex-row flex-wrap gap-2">
          {postTags.map((tag) => (
            <div class="flex items-center justify-center rounded-full border border-sky-200/50 bg-sky-100/50 px-3 py-1 text-[10px] font-bold uppercase tracking-[0.18em] text-sky-700 shadow-[0_0_10px_rgba(46,64,54,0.05)] lg:text-xs">
              {tag}
            </div>
          ))}
        </div>

        <div class="flex items-center gap-2">
           <button id="share-article" type="button" class="inline-flex min-h-10 items-center justify-center rounded-full border border-slate-200 bg-white px-4 text-sm font-semibold text-slate-700 shadow-[0_18px_36px_-30px_rgba(15,23,42,0.65)] transition-[background-color,transform] hover:bg-slate-50 hover:text-slate-900 active:scale-[0.96]">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/></svg>
              <span data-share-label>Share</span>
           </button>
        </div>
      </div>

      <div class="w-full py-12 lg:py-16">
        <div class="prose prose-slate mx-auto max-w-3xl prose-lg prose-headings:font-bold prose-headings:tracking-tight prose-headings:text-slate-900 prose-headings:scroll-mt-28 prose-p:text-[1.08rem] prose-p:leading-8 prose-p:text-slate-700 prose-a:font-semibold prose-a:text-sky-700 hover:prose-a:text-sky-900 prose-a:underline prose-a:decoration-sky-200 prose-a:underline-offset-4 prose-img:rounded-[1.75rem] prose-img:outline prose-img:outline-1 prose-img:outline-black/10 prose-img:shadow-[0_22px_60px_-32px_rgba(15,23,42,0.35)] prose-hr:my-12 prose-hr:border-slate-200 prose-blockquote:rounded-r-[1.5rem] prose-blockquote:border-l-4 prose-blockquote:border-sky-300 prose-blockquote:bg-sky-50/60 prose-blockquote:px-6 prose-blockquote:py-4 prose-blockquote:font-editorial prose-blockquote:text-[1.2rem] prose-blockquote:not-italic prose-blockquote:text-slate-700 prose-li:my-1.5 prose-li:marker:text-sky-400 prose-strong:font-bold prose-strong:text-slate-900 prose-pre:rounded-[1.5rem] prose-pre:border prose-pre:border-slate-800 prose-pre:shadow-2xl prose-table:rounded-2xl prose-table:border prose-table:border-slate-200">
        <Content />
        </div>
      </div>
    </article>

    <footer class="mt-16 border-t border-slate-200 pt-10">
      <p class="text-center text-sm text-slate-500">
        Questions about Search Console workflows or conversational SEO?{' '}
        <a href="https://www.aichatseo.com/sign-up" class="font-medium text-sky-700 hover:underline">
          Start free on AIChatSEO
        </a>
      </p>
    </footer>
  </main>
</Layout>

<script>
  const shareButton = document.getElementById('share-article');
  const shareLabel = shareButton?.querySelector('[data-share-label]');

  shareButton?.addEventListener('click', async () => {
    const shareUrl = window.location.href;
    const shareData = {
      title: document.title,
      text: 'Read this article on AIChatSEO',
      url: shareUrl,
    };

    if (navigator.share) {
      await navigator.share(shareData).catch(() => {});
      return;
    }

    if (navigator.clipboard?.writeText) {
      await navigator.clipboard.writeText(shareUrl).catch(() => {});
      if (shareLabel) shareLabel.textContent = 'Link copied';
      window.setTimeout(() => {
        if (shareLabel) shareLabel.textContent = 'Share';
      }, 1800);
    }
  });
</script>
