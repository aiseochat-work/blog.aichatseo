---
import { desc as descOrder } from 'drizzle-orm';
import { db, ensureDatabaseReady } from '../db';
import { posts } from '../db/schema';
import Layout from '../layouts/Layout.astro';
import { setBlogCacheHeaders } from '../lib/cache';
import { absoluteUrl } from '../lib/site-url';

await ensureDatabaseReady();
const allPosts = await db.select().from(posts).orderBy(descOrder(posts.createdAt));

const pageDescription =
  'Practical notes on conversational SEO, Search Console signals, and making search performance easier to act on — from the AIChatSEO team.';

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'AIChatSEO Blog',
  url: absoluteUrl('/'),
  description: pageDescription,
  publisher: {
    '@type': 'Organization',
    name: 'AIChatSEO',
    url: 'https://www.aichatseo.com',
  },
  blogPost: allPosts.map((post) => ({
    '@type': 'BlogPosting',
    headline: post.title,
    url: absoluteUrl(`/blog/${post.slug}`),
    datePublished: post.createdAt?.toISOString(),
    dateModified: post.updatedAt?.toISOString(),
    author: {
      '@type': 'Person',
      name: post.author?.trim() || 'AIChatSEO Team',
    },
    keywords: post.tags || [],
  })),
};

const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'AIChatSEO Blog Posts',
  itemListElement: allPosts.map((post, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: absoluteUrl(`/blog/${post.slug}`),
    name: post.title,
  })),
};

setBlogCacheHeaders(Astro.response.headers);
---

<Layout
  title="Blog | AIChatSEO"
  description={pageDescription}
  jsonLd={[websiteLd, itemListLd]}
  googleSiteVerification="P5UdfSYTpwMutruALFkfTCe4vo4il6SHc2eyts-5MsY"
>
  <main class="mx-auto max-w-6xl px-4 pb-20 pt-4 sm:px-6 sm:pt-8">
    <section class="overflow-hidden rounded-[2rem] border border-slate-200/80 bg-white/85 shadow-float backdrop-blur">
      <div class="grid gap-10 p-6 sm:p-10 lg:grid-cols-[1.05fr_0.95fr] lg:p-12">
        <div class="flex flex-col justify-center">
          <p
            class="mb-5 inline-flex w-fit items-center rounded-full border border-sky-200/80 bg-sky-50 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.2em] text-sky-900"
          >
            Conversational SEO intelligence
          </p>
          <h1 class="max-w-3xl text-4xl font-extrabold tracking-tight text-slate-950 sm:text-5xl lg:text-6xl">
            Ask first. Investigate faster.
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-600">
            Practical notes from AIChatSEO on diagnosing visibility shifts, finding striking-distance pages,
            and turning Search Console signals into action.
          </p>
          <div class="mt-8 flex flex-wrap gap-3 text-sm font-medium">
            <a
              href="https://www.aichatseo.com/sign-up"
              class="rounded-full bg-slate-950 px-5 py-3 text-white shadow-soft transition hover:bg-sky-700"
            >
              Start free
            </a>
            <a
              href="https://www.aichatseo.com/#features"
              class="rounded-full border border-slate-200 bg-white px-5 py-3 text-slate-700 transition hover:border-sky-200 hover:text-sky-800"
            >
              Explore product
            </a>
          </div>
        </div>
        <div class="rounded-[1.75rem] border border-slate-200 bg-slate-950 p-5 text-white shadow-soft">
          <div class="mb-5 flex items-center justify-between text-xs text-slate-400">
            <span>[DIAGNOSTIC_ACTIVE]</span>
            <span>LCP 1.2s</span>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
            <p class="text-sm text-sky-200">AIChat Assistant</p>
            <p class="mt-3 text-lg font-semibold">Why did traffic drop on /blog yesterday?</p>
            <p class="mt-4 text-sm leading-6 text-slate-300">
              Impressions fell across a small query cluster. Rankings were mostly stable, so refresh
              time-sensitive examples and resubmit key URLs.
            </p>
          </div>
          <div class="mt-4 grid grid-cols-3 gap-3 text-center text-xs">
            <div class="rounded-2xl bg-white/5 p-3">
              <p class="text-lg font-bold text-white">-14%</p>
              <p class="mt-1 text-slate-400">Impressions</p>
            </div>
            <div class="rounded-2xl bg-white/5 p-3">
              <p class="text-lg font-bold text-white">4.8</p>
              <p class="mt-1 text-slate-400">Avg pos.</p>
            </div>
            <div class="rounded-2xl bg-white/5 p-3">
              <p class="text-lg font-bold text-white">Fix</p>
              <p class="mt-1 text-slate-400">Next move</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mt-12">
      <div class="mb-6 flex flex-col justify-between gap-3 sm:flex-row sm:items-end">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-800">Latest insights</p>
          <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-950">Search performance playbooks</h2>
        </div>
        <p class="max-w-md text-sm leading-6 text-slate-500">
          Clear workflows for SEO teams that want less dashboard friction and faster decisions.
        </p>
      </div>
      <div class="grid gap-6">
      {
        allPosts.length === 0 ? (
          <div class="rounded-4xl border border-slate-200 bg-white p-10 text-center shadow-float">
            <p class="text-slate-600">No posts yet.</p>
            <p class="mt-2 text-sm text-slate-500">Add posts through your database or run the protected seed utility in development.</p>
          </div>
        ) : (
          allPosts.map((post) => (
            <article>
              <a
                href={`/blog/${post.slug}`}
                class="group block overflow-hidden rounded-[1.75rem] border border-slate-200/90 bg-white shadow-soft transition hover:-translate-y-0.5 hover:border-sky-200 hover:shadow-float"
              >
                <div class="flex flex-col sm:flex-row">
                  {post.coverImage ? (
                    <div class="relative aspect-[16/10] w-full shrink-0 sm:w-72 lg:w-80">
                      <img
                        src={post.coverImage}
                        alt=""
                        class="h-full w-full object-cover"
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                  ) : (
                    <div class="relative flex aspect-[16/10] w-full shrink-0 items-center justify-center bg-gradient-to-br from-sky-100 to-slate-100 sm:aspect-auto sm:w-56">
                      <span class="text-4xl font-black text-sky-300/90" aria-hidden="true">
                        AI
                      </span>
                    </div>
                  )}
                  <div class="flex flex-1 flex-col justify-center p-6 sm:p-8 lg:p-10">
                    {post.tags?.length ? (
                      <ul class="mb-3 flex flex-wrap gap-2">
                        {post.tags.map((t) => (
                          <li>
                            <span class="rounded-full bg-sky-50 px-2.5 py-0.5 text-xs font-medium text-sky-800">
                              {t}
                            </span>
                          </li>
                        ))}
                      </ul>
                    ) : null}
                    <h2 class="text-2xl font-bold text-slate-900 transition group-hover:text-sky-800">
                      {post.title}
                    </h2>
                    {post.excerpt ? <p class="mt-3 line-clamp-3 text-slate-600">{post.excerpt}</p> : null}
                    <div class="mt-5 flex flex-wrap items-center gap-3 text-sm text-slate-500">
                      <time datetime={post.createdAt!.toISOString()}>
                        {new Date(post.createdAt!).toLocaleDateString(undefined, { dateStyle: 'long' })}
                      </time>
                      <span class="font-medium text-sky-600">Read article →</span>
                    </div>
                  </div>
                </div>
              </a>
            </article>
          ))
        )
      }
      </div>
    </section>
  </main>
</Layout>
