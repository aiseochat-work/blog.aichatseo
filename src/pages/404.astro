---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page not found | AIChatSEO" description="This page could not be found." noindex>
  <main class="mx-auto max-w-lg px-6 py-24 text-center">
    <p class="text-sm font-semibold uppercase tracking-wide text-sky-800">404</p>
    <h1 class="mt-2 text-3xl font-bold text-slate-900">This page isn’t here</h1>
    <p class="mt-4 text-slate-600">The page may have moved or the link is wrong.</p>
    <a
      href="/"
      class="mt-8 inline-flex rounded-full bg-sky-500 px-6 py-3 text-sm font-semibold text-white shadow-soft transition hover:bg-sky-600"
    >
      Back to blog
    </a>
    <p class="mt-10">
      <a href="https://www.aichatseo.com" class="text-sm font-medium text-sky-700 hover:underline">
        Go to AIChatSEO →
      </a>
    </p>
  </main>
</Layout>
