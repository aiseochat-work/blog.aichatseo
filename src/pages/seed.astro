---
import { inArray } from 'drizzle-orm';
import { db, ensureDatabaseReady } from '../db';
import { posts } from '../db/schema';
import Layout from '../layouts/Layout.astro';

const SEED_SLUGS = ['ai-chat-seo-revolution', 'optimizing-for-llm-crawlers'] as const;
const seedToken = import.meta.env.SEED_TOKEN as string | undefined;
const requestToken = Astro.url.searchParams.get('token') || Astro.request.headers.get('x-seed-token');
const canSeed = import.meta.env.DEV || (!!seedToken && requestToken === seedToken);

let message = canSeed
  ? 'Use the button below to add two sample posts, or refresh existing sample posts.'
  : 'Seed is disabled. Set SEED_TOKEN and pass ?token=... to use this utility outside local development.';

if (Astro.request.method === 'POST') {
  try {
    if (!canSeed) {
      Astro.response.status = 403;
      throw new Error('Seed token is missing or invalid.');
    }

    await ensureDatabaseReady();

    await db.delete(posts).where(inArray(posts.slug, [...SEED_SLUGS]));

    await db.insert(posts).values([
      {
        title: 'How AI Chat is Reshaping SEO in 2026',
        slug: 'ai-chat-seo-revolution',
        excerpt:
          'Search is conversational. Here is how to optimize for intent, structure, and signals teams can act on — not vanity metrics.',
        metaDescription:
          'Why conversational search changes SEO priorities in 2026 and practical steps: semantic relevance, structured data, and fast experiences.',
        author: 'AIChatSEO Team',
        tags: ['AI search', 'SEO strategy', '2026'],
        content: `
                    <h2>The shift to conversational questions</h2>
                    <p>People ask longer, more specific questions — to search engines and to assistants. Winning pages answer clearly and cite structure that machines and humans can scan.</p>
                    <p>To stay visible, optimize for <strong>intent</strong> and <strong>clarity</strong>: direct answers, trustworthy sourcing, and content that maps to real queries in Search Console.</p>
                    <ul>
                        <li>Build semantic depth around topics, not isolated keywords.</li>
                        <li>Use structured data where it reflects the page honestly.</li>
                        <li>Keep critical content fast and easy to crawl.</li>
                    </ul>
                `,
      },
      {
        title: 'Optimizing for LLM and AI Crawlers',
        slug: 'optimizing-for-llm-crawlers',
        excerpt:
          'How GPT-Bot, Claude-Bot, and similar agents consume pages — and how to make your facts and structure easy to trust.',
        metaDescription:
          'Practical guidance for LLM-facing crawlers: robots rules, clarity, structure, and performance so your best content can be understood.',
        author: 'AIChatSEO Team',
        tags: ['LLM', 'Technical SEO', 'Crawlers'],
        content: `
                    <h2>Clarity beats decoration</h2>
                    <p>Assistants reward pages that separate facts from fluff. Use descriptive headings, short paragraphs, and explicit lists when they help the reader.</p>
                    <p>Review which user agents you allow and ensure your <code>robots.txt</code> reflects your publishing goals — allow or disallow thoughtfully per crawler policy.</p>
                    <p>Performance still matters: slow responses increase abandonment for humans and can limit how deeply crawlers explore your site.</p>
                `,
      },
    ]);
    message = 'Sample posts were added. Return to the blog home to read them.';
  } catch (e: unknown) {
    message = 'Seed failed: ' + (e instanceof Error ? e.message : String(e));
  }
}
---

<Layout title="Seed posts | AIChatSEO" description="Admin utility to insert sample blog posts." noindex>
  <main class="mx-auto max-w-md px-6 py-16">
    <div class="rounded-4xl border border-slate-200 bg-white p-8 shadow-float">
      <h1 class="text-2xl font-bold text-slate-900">Seed posts</h1>
      <p class="mt-3 text-slate-600">{message}</p>
      <form method="POST" class="mt-8 space-y-4">
        <button
          type="submit"
          disabled={!canSeed}
          class="w-full rounded-full bg-sky-500 py-3 text-sm font-semibold text-white shadow-soft transition hover:bg-sky-600 disabled:cursor-not-allowed disabled:bg-slate-300"
        >
          Insert two sample posts
        </button>
      </form>
      <a href="/" class="mt-6 block text-center text-sm font-medium text-sky-700 hover:underline">← Blog home</a>
    </div>
  </main>
</Layout>
