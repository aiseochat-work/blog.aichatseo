---
import { db, ensureDatabaseReady } from '../../db';
import { posts } from '../../db/schema';
import { eq } from 'drizzle-orm';
import Layout from '../../layouts/Layout.astro';
import { preparePostContent, wordCountFromHtml } from '../../lib/post-content';
import { readingTimeMinutes } from '../../lib/reading-time';
import { setBlogCacheHeaders } from '../../lib/cache';
import { absoluteUrl, canonicalFromRequest } from '../../lib/site-url';

const { slug } = Astro.params;
await ensureDatabaseReady();
const post = await db.query.posts.findFirst({
  where: eq(posts.slug, slug!),
});

if (!post) {
  Astro.response.status = 404;
}

const DEFAULT_AUTHOR = 'AIChatSEO Team';

const articleDesc =
  post?.metaDescription?.trim() ||
  post?.excerpt?.trim() ||
  (post ? `${post.title} — insights from the AIChatSEO blog.` : 'Page not found.');

const ogImage =
  post?.coverImage?.trim() ? absoluteUrl(post.coverImage) : undefined;

const publishedIso = post?.createdAt?.toISOString();
const modifiedIso = post?.updatedAt?.toISOString();
const authorName = post?.author?.trim() || DEFAULT_AUTHOR;
const readMins = post ? readingTimeMinutes(post.content) : 0;
const preparedContent = post ? preparePostContent(post.content) : null;
const articleUrl = canonicalFromRequest(Astro.url);
const postTags = post?.tags?.filter(Boolean) || [];

const articleLd = post
  ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: post.title,
      description: articleDesc,
      url: articleUrl,
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': articleUrl,
      },
      datePublished: publishedIso,
      dateModified: modifiedIso,
      author: { '@type': 'Person', name: authorName },
      publisher: {
        '@type': 'Organization',
        name: 'AIChatSEO',
        url: 'https://www.aichatseo.com',
        logo: {
          '@type': 'ImageObject',
          url: absoluteUrl('/favicon.svg'),
        },
      },
      image: ogImage ? [ogImage] : [absoluteUrl('/favicon.svg')],
      articleSection: postTags[0] || 'SEO',
      keywords: postTags,
      wordCount: wordCountFromHtml(post.content),
    }
  : null;

const breadcrumbLd = post
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Blog',
          item: absoluteUrl('/'),
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: post.title,
          item: articleUrl,
        },
      ],
    }
  : null;

setBlogCacheHeaders(Astro.response.headers);
---

{
  post ? (
    <Layout
      title={`${post.title} | AIChatSEO`}
      description={articleDesc}
      ogImage={ogImage}
      ogType="article"
      articlePublishedTime={publishedIso}
      articleModifiedTime={modifiedIso}
      jsonLd={[articleLd!, breadcrumbLd!]}
    >
      <main class="mx-auto max-w-7xl px-4 pb-24 pt-6 sm:px-6 sm:pt-10">
        <a
          href="/"
          class="inline-flex items-center gap-1 text-sm font-medium text-sky-700 transition hover:text-sky-900"
        >
          ← All posts
        </a>

        <article class="mt-8 rounded-[2rem] border border-slate-200/90 bg-white shadow-float">
          <header class="rounded-t-[2rem] border-b border-slate-200 bg-gradient-to-br from-white via-sky-50/60 to-slate-50 p-6 sm:p-10 lg:p-12">
            <div class="mx-auto max-w-3xl">
              {postTags.length ? (
                <ul class="mb-5 flex flex-wrap gap-2">
                  {postTags.map((t) => (
                    <li>
                      <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-sky-900 ring-1 ring-sky-100">
                        {t}
                      </span>
                    </li>
                  ))}
                </ul>
              ) : null}

              <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-slate-500">
                <time datetime={publishedIso}>{new Date(post.createdAt!).toLocaleDateString(undefined, { dateStyle: 'long' })}</time>
                <span aria-hidden="true">·</span>
                <span>{readMins} min read</span>
                <span aria-hidden="true">·</span>
                <span>{authorName}</span>
              </div>

              <h1 class="mt-6 text-4xl font-extrabold tracking-tight text-slate-950 sm:text-5xl sm:leading-tight">
                {post.title}
              </h1>

              {post.excerpt ? <p class="mt-6 text-xl leading-relaxed text-slate-600">{post.excerpt}</p> : null}
            </div>

            {post.coverImage ? (
              <div class="mx-auto mt-10 max-w-4xl overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-soft">
                <img
                  src={post.coverImage}
                  alt=""
                  class="aspect-[1200/630] w-full object-cover"
                  width={1200}
                  height={630}
                />
              </div>
            ) : null}
          </header>

          <div class="grid gap-10 px-6 py-10 md:grid-cols-[14rem_minmax(0,1fr)] lg:grid-cols-[15rem_minmax(0,44rem)_1fr] lg:px-10 lg:py-12">
            <aside class="hidden md:block">
              <div class="sticky top-28 rounded-3xl border border-slate-200 bg-slate-50/80 p-5">
                <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">On this page</p>
                {preparedContent?.toc.length ? (
                  <nav class="mt-4" aria-label="Table of contents">
                    <ol class="space-y-2 text-sm">
                      {preparedContent.toc.map((item) => (
                        <li class:list={[item.depth === 3 && 'pl-4']}>
                          <a
                            href={`#${item.id}`}
                            class="block rounded-xl px-3 py-2 text-slate-600 transition hover:bg-white hover:text-sky-800"
                          >
                            {item.text}
                          </a>
                        </li>
                      ))}
                    </ol>
                  </nav>
                ) : (
                  <p class="mt-4 text-sm leading-6 text-slate-500">This article is short enough to read straight through.</p>
                )}
              </div>
            </aside>

            {preparedContent?.toc.length ? (
              <details class="rounded-3xl border border-slate-200 bg-slate-50 p-5 md:hidden">
                <summary class="cursor-pointer text-sm font-semibold text-slate-900">Table of contents</summary>
                <ol class="mt-4 space-y-2 text-sm">
                  {preparedContent.toc.map((item) => (
                    <li class:list={[item.depth === 3 && 'pl-4']}>
                      <a href={`#${item.id}`} class="text-slate-600 hover:text-sky-800">
                        {item.text}
                      </a>
                    </li>
                  ))}
                </ol>
              </details>
            ) : null}

            <div
              class="prose prose-slate prose-lg max-w-none prose-headings:scroll-mt-28 prose-headings:font-bold prose-headings:text-slate-950 prose-a:text-sky-700 prose-a:no-underline hover:prose-a:underline prose-strong:text-slate-900 prose-code:rounded-md prose-code:bg-slate-100 prose-code:px-1 prose-code:py-0.5 prose-code:text-slate-800 prose-pre:bg-slate-900 prose-pre:text-slate-100"
            >
              <div set:html={preparedContent!.html} />
            </div>
          </div>
        </article>

        <footer class="mt-16 border-t border-slate-200 pt-10">
          <p class="text-center text-sm text-slate-500">
            Questions about Search Console workflows or conversational SEO?{' '}
            <a href="https://www.aichatseo.com/sign-up" class="font-medium text-sky-700 hover:underline">
              Start free on AIChatSEO
            </a>
          </p>
        </footer>
      </main>
    </Layout>
  ) : (
    <Layout title="Page not found | AIChatSEO" description="This post could not be found." noindex>
      <main class="mx-auto max-w-lg px-6 py-24 text-center">
        <p class="text-sm font-semibold uppercase tracking-wide text-sky-800">404</p>
        <h1 class="mt-2 text-3xl font-bold text-slate-900">This page isn’t here</h1>
        <p class="mt-4 text-slate-600">The article may have moved or the link is wrong.</p>
        <a
          href="/"
          class="mt-8 inline-flex rounded-full bg-sky-500 px-6 py-3 text-sm font-semibold text-white shadow-soft transition hover:bg-sky-600"
        >
          Back to blog
        </a>
      </main>
    </Layout>
  )
}
