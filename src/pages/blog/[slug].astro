---
import { db, ensureDatabaseReady } from '../../db';
import { posts } from '../../db/schema';
import { eq } from 'drizzle-orm';
import Layout from '../../layouts/Layout.astro';
import { preparePostContent, wordCountFromHtml } from '../../lib/post-content';
import { readingTimeMinutes } from '../../lib/reading-time';
import { setBlogCacheHeaders } from '../../lib/cache';
import { absoluteUrl, canonicalFromRequest } from '../../lib/site-url';

const { slug } = Astro.params;
await ensureDatabaseReady();
const post = await db.query.posts.findFirst({
  where: eq(posts.slug, slug!),
});

if (!post) {
  Astro.response.status = 404;
}

const DEFAULT_AUTHOR = 'AIChatSEO Team';

const articleDesc =
  post?.metaDescription?.trim() ||
  post?.excerpt?.trim() ||
  (post ? `${post.title} — insights from the AIChatSEO blog.` : 'Page not found.');

const ogImage =
  post?.coverImage?.trim() ? absoluteUrl(post.coverImage) : undefined;

const publishedIso = post?.createdAt?.toISOString();
const modifiedIso = post?.updatedAt?.toISOString();
const authorName = post?.author?.trim() || DEFAULT_AUTHOR;
const readMins = post ? readingTimeMinutes(post.content) : 0;
const preparedContent = post ? preparePostContent(post.content) : null;
const articleUrl = canonicalFromRequest(Astro.url);
const postTags = post?.tags?.filter(Boolean) || [];

const articleLd = post
  ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: post.title,
      description: articleDesc,
      url: articleUrl,
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': articleUrl,
      },
      datePublished: publishedIso,
      dateModified: modifiedIso,
      author: { '@type': 'Person', name: authorName },
      publisher: {
        '@type': 'Organization',
        name: 'AIChatSEO',
        url: 'https://www.aichatseo.com',
        logo: {
          '@type': 'ImageObject',
          url: absoluteUrl('/favicon.svg'),
        },
      },
      image: ogImage ? [ogImage] : [absoluteUrl('/favicon.svg')],
      articleSection: postTags[0] || 'SEO',
      keywords: postTags,
      wordCount: wordCountFromHtml(post.content),
    }
  : null;

const breadcrumbLd = post
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Blog',
          item: absoluteUrl('/'),
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: post.title,
          item: articleUrl,
        },
      ],
    }
  : null;

setBlogCacheHeaders(Astro.response.headers);
---

{
  post ? (
    <Layout
      title={`${post.title} | AIChatSEO`}
      description={articleDesc}
      ogImage={ogImage}
      ogType="article"
      articlePublishedTime={publishedIso}
      articleModifiedTime={modifiedIso}
      jsonLd={[articleLd!, breadcrumbLd!]}
    >
      <main class="mx-auto max-w-4xl px-4 pb-24 pt-6 sm:px-6 sm:pt-10">
        <article class="flex flex-col items-center">
          <header class="mb-16 flex w-full flex-col items-center justify-center text-center">
            <div class="mb-10 flex w-full justify-start">
              <a
                href="/"
                class="group inline-flex items-center gap-2 rounded-full border border-white/60 bg-white/50 px-4 py-2 text-sm font-bold text-slate-700 shadow-sm backdrop-blur-md transition-all hover:bg-white hover:shadow-md hover:-translate-y-0.5"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-1"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
                Back to blogs
              </a>
            </div>
            
            <p class="inline-flex items-center gap-2 rounded-full border border-[#80c4e9]/30 bg-[#80c4e9]/10 px-4 py-1.5 text-[11px] font-mono font-bold uppercase tracking-widest text-[#3b7597] mb-8 shadow-sm backdrop-blur-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#80c4e9]"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
              {new Date(post.createdAt!).toLocaleDateString("en-GB", {
                day: "2-digit",
                month: "short",
                year: "numeric",
              })}
              <span class="mx-1 h-3 w-px bg-[#80c4e9]/40"></span>
              {readMins} min read
            </p>
            
            <h1 class="mb-6 text-4xl font-extrabold leading-[1.1] tracking-tight text-slate-800 md:text-5xl lg:text-6xl max-w-4xl">
              {post.title}
            </h1>
            
            {post.excerpt && (
              <p class="max-w-2xl text-lg font-medium leading-relaxed text-slate-500 lg:text-xl">
                {post.excerpt}
              </p>
            )}

            <div class="flex flex-row gap-4 mt-10 items-center rounded-2xl border border-white/60 bg-white/40 p-2 pr-6 shadow-sm backdrop-blur-md">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-[#80c4e9] to-sky-600 shadow-inner">
                <span class="text-white font-bold text-lg">{authorName[0]}</span>
              </div>
              <div class="text-sm text-left flex flex-col justify-center">
                <p class="text-slate-800 font-bold text-base leading-tight">
                  {authorName}
                </p>
                <p class="text-slate-500 font-mono uppercase tracking-widest text-[10px] mt-0.5">
                  Author
                </p>
              </div>
            </div>

            {post.coverImage && (
              <div class="relative w-full max-w-5xl mt-14 lg:mt-20 group">
                {/* Glow effect behind image */}
                <div class="absolute -inset-4 rounded-[2rem] bg-sky-200/40 opacity-0 blur-2xl transition-opacity duration-700 group-hover:opacity-100"></div>
                <div class="relative h-[300px] lg:h-[500px] w-full overflow-hidden rounded-[2rem] border border-white/40 shadow-[0_32px_64px_-24px_rgba(15,23,42,0.15)] ring-1 ring-slate-900/5">
                  <img
                    src={post.coverImage}
                    alt={post.title}
                    class="h-full w-full object-cover transition-transform duration-1000 group-hover:scale-105"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-slate-900/10 via-transparent to-transparent"></div>
                </div>
              </div>
            )}
          </header>

          <div class="flex w-full flex-col gap-6 rounded-[2rem] border border-slate-200 bg-white/80 px-6 py-6 shadow-[0_18px_50px_-38px_rgba(15,23,42,0.28)] backdrop-blur-xl sm:flex-row sm:items-center sm:justify-between">
            <div class="flex flex-row flex-wrap gap-2">
              {postTags.map((tag) => (
                <div class="flex items-center justify-center text-[10px] lg:text-xs px-3 py-1 rounded-full text-sky-700 bg-sky-100/50 border border-sky-200/50 font-mono tracking-widest uppercase shadow-[0_0_10px_rgba(46,64,54,0.05)]">
                  {tag}
                </div>
              ))}
            </div>
            
            <!-- Removed dynamic Next.js ShareBtn, replaced with static placeholder for UI -->
            <div class="flex items-center gap-2">
               <button class="inline-flex h-9 items-center justify-center rounded-md border border-slate-200 bg-white px-3 text-sm font-medium shadow-sm transition-colors hover:bg-slate-100 hover:text-slate-900">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/></svg>
                  Share
               </button>
            </div>
          </div>

          <div class="py-12 lg:py-16 w-full prose prose-slate prose-lg max-w-none prose-headings:font-bold prose-a:text-sky-600 hover:prose-a:text-sky-800 prose-img:rounded-xl">
            <div set:html={preparedContent!.html} />
          </div>
        </article>

        <footer class="mt-16 border-t border-slate-200 pt-10">
          <p class="text-center text-sm text-slate-500">
            Questions about Search Console workflows or conversational SEO?{' '}
            <a href="https://www.aichatseo.com/sign-up" class="font-medium text-sky-700 hover:underline">
              Start free on AIChatSEO
            </a>
          </p>
        </footer>
      </main>
    </Layout>
  ) : (
    <Layout title="Page not found | AIChatSEO" description="This post could not be found." noindex>
      <main class="mx-auto max-w-lg px-6 py-24 text-center">
        <p class="text-sm font-semibold uppercase tracking-wide text-sky-800">404</p>
        <h1 class="mt-2 text-3xl font-bold text-slate-900">This page isn’t here</h1>
        <p class="mt-4 text-slate-600">The article may have moved or the link is wrong.</p>
        <a
          href="/"
          class="mt-8 inline-flex rounded-full bg-sky-500 px-6 py-3 text-sm font-semibold text-white shadow-soft transition hover:bg-sky-600"
        >
          Back to blog
        </a>
      </main>
    </Layout>
  )
}
